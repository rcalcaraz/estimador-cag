OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Orden del router LiteLLM: openai intenta primero gpt; anthropic intenta primero Claude.
LLM_PROVIDER=openai
# Legado; preferible PRIMARY_MODEL y FALLBACK_MODEL.
LLM_MODEL=gpt-4o-mini
PRIMARY_MODEL=gpt-4o-mini
FALLBACK_MODEL=claude-haiku-4-5
LLM_TIMEOUT=30
LLM_RETRIES=2
# Local sin Docker: Redis en tu máquina (puerto 6379).
# Docker Compose: redis://redis:6379 (nombre del servicio en la red de Compose).
# RedisInsight con Compose: http://localhost:8001
REDIS_URL=redis://localhost:6379
CACHE_TTL=86400
# Caché semántica (requiere OPENAI_API_KEY y Redis Stack con RediSearch)
EMBEDDING_MODEL=text-embedding-3-small
SEMANTIC_CACHE_THRESHOLD=0.85
SEMANTIC_CACHE_TTL=86400
# true = solo registra hits potenciales, no los sirve (calibración)
SEMANTIC_CACHE_LOG_ONLY=false
APP_ENV=
LOG_LEVEL=
