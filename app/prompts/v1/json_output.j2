<output_format required="json">
  <instructions>
    Responde únicamente con un objeto JSON válido: sin markdown, sin texto antes ni después, sin bloques de código.
  </instructions>

  <schema language="same_as_project_description">
{
  "summary": "Una frase que resume el alcance y los supuestos principales de la estimación.",
  "phases": [
    {
      "name": "Discovery & Requirements",
      "description": "Breve párrafo (2–4 frases) sobre el trabajo de esta fase.",
      "weeks": 2,
      "cost": 2500
    }
  ],
  "totals": {
    "duration_weeks": 10,
    "cost": 32500,
    "confidence_pct": 65,
    "currency": "EUR"
  }
}
  </schema>

  <rules>
    <rule field="summary">Una sola frase introductoria (como en un informe para el cliente).</rule>
    <rule field="phases">Lista ordenada de fases u hitos; cada una con `name`, `description`, `weeks` (número, puede ser decimal) y `cost` en la moneda de `totals.currency`.</rule>
    <rule field="totals.duration_weeks">Suma coherente con las semanas de las fases (redondeo razonable).</rule>
    <rule field="totals.cost">Suma coherente con los costes por fase.</rule>
    <rule field="totals.confidence_pct">Confianza global (0–100) en la estimación agregada.</rule>
    <rule>No incluyas campos extra (sin supuestos por ítem, sin equipo, sin riesgos en JSON).</rule>
{% if detail_level.value == "summary" %}
    <rule detail_level="summary">3–5 fases como máximo; descripciones concisas (1–2 frases).</rule>
{% elif detail_level.value == "detailed" %}
    <rule detail_level="detailed">Descripciones algo más ricas (hasta 4 frases por fase).</rule>
{% else %}
    <rule detail_level="medium">Equilibrio entre número de fases y detalle en cada `description`.</rule>
{% endif %}
  </rules>
</output_format>
